# Local environment and machine-specific files
.env
.env.*
!.env.example

# Root dependency/build directories
/vendor/
/node_modules/
/.cache/

# Runtime storage generated by CodeIgniter/RISE
/writable/*
!/writable/.htaccess
!/writable/index.html
!/writable/cache/
/writable/cache/*
!/writable/cache/index.html
!/writable/debugbar/
/writable/debugbar/*
!/writable/debugbar/index.html
!/writable/logs/
/writable/logs/*
!/writable/logs/index.html
!/writable/session/
/writable/session/*
!/writable/session/index.html
!/writable/uploads/
/writable/uploads/*
!/writable/uploads/index.html

# User uploads and temporary import/export files
/files/*
!/files/index.html
!/files/general/
/files/general/*
!/files/general/index.html
!/files/profile_images/
/files/profile_images/*
!/files/profile_images/index.html
!/files/project_files/
/files/project_files/*
!/files/project_files/index.html
!/files/system/
/files/system/*
!/files/system/index.html
!/files/system/1px.jpg
!/files/system/default-invoice-logo.png
!/files/system/import-*-sample.xlsx
!/files/system/notification.mp3
!/files/system/store-item-no-image.png
!/files/system/pwa/
/files/system/pwa/*
!/files/system/pwa/index.html
!/files/system/pwa/default-pwa-icon.png
!/files/temp/
/files/temp/*
!/files/temp/index.html
!/files/timeline_files/
/files/timeline_files/*
!/files/timeline_files/index.html

# Generated packages and disabled installers
/plugins/*.zip
/install_disabled_*/
